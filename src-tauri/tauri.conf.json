{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WoW Gear Sim",
  "version": "0.2.1",
  "identifier": "com.marikamella.wow-gear-sim",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WoW Gear Sim",
        "width": 1200,
        "height": 800
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/simc"],
    "resources": ["assets/items.db"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "shell": {
      "open": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5RkQwQTA4NjkzQjE0OTEKUldTUkZEdHBDQXI5V2ZKQWVSWFFqUWlWOXRncVhIOFNHYk5ISGdNT3JCc1FRV3lZL3RSSDUzbVoK",
      "endpoints": [
        "https://github.com/marikadeveloper/wow-dmg-simulator/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
